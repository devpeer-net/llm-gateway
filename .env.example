# ─── Runtime ────────────────────────────────────────────────────────────────
# Port the HTTP server listens on.
PORT=3333
# Number of proxy hops to trust for req.ip / X-Forwarded-For (0 = off).
TRUST_PROXY_HOPS=0
# Max JSON request body size (mirrored in the Nginx template).
JSON_BODY_LIMIT=10mb
# Server/stream timeout in milliseconds.
REQUEST_TIMEOUT_MS=300000

# ─── LLM provider API keys ──────────────────────────────────────────────────
# Provide the keys for whichever engines you intend to use. Missing keys simply
# disable that engine (and its models are skipped by the e2e suite).
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ─── Authentication ─────────────────────────────────────────────────────────
# 'jwt' (default) verifies a Bearer JWT; 'none' disables auth (recommended for
# local/dev — a synthetic user id is injected so quota/logging keep working).
AUTH_MODE=none
# One of the following key sources is required when AUTH_MODE=jwt:
AUTH_JWKS_URL=
AUTH_JWT_PUBLIC_KEY=
AUTH_JWT_SECRET=
# Optional issuer / audience validation.
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
# Claim to use as the stable user id (default 'sub').
AUTH_USER_ID_CLAIM=sub
# Synthetic user id injected in no-auth mode.
AUTH_DEV_USER_ID=local-dev

# ─── Quota store ────────────────────────────────────────────────────────────
# 'memory' (default, no AWS) or 'dynamodb' (production).
QUOTA_STORE=memory
# Only required when QUOTA_STORE=dynamodb:
API_USAGE_TABLE=apiUsage
AWS_REGION=us-east-1

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=450

# ─── Proxy models (optional) ────────────────────────────────────────────────
# Override the virtual model registry with a JSON object. Each key is a proxy
# id mapping to an ordered model list and an optional OpenRouter fallback.
# PROXY_MODELS_JSON={"gateway-fast":{"models":["gemini-2.5-flash","gpt-4o-mini"],"openRouterFallback":"google/gemini-2.5-flash"}}

# ─── Deploy-only (deploy/deploy.sh) ─────────────────────────────────────────
DEPLOY_AWS_ACCOUNT_ID=
DEPLOY_EB_APP=
DEPLOY_EB_ENV=
DEPLOY_S3_BUCKET=
DEPLOY_AWS_PROFILE=
